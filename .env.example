"""Environment configuration template"""
# Copy this file to .env and add your API key

# OpenWeather API Key (Get it from https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_api_key_here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Cache Configuration
CACHE_TIMEOUT=600

# Temperature Unit: metric (Celsius), imperial (Fahrenheit), standard (Kelvin)
TEMPERATURE_UNIT=metric

# Wind Unit: mps (m/s), kmh (km/h), mph
WIND_UNIT=mps

# Pressure Unit: hpa (hectopascal), mb (millibar), inhg (inchHg)
PRESSURE_UNIT=hpa

# Default Location
DEFAULT_CITY=Tehran
DEFAULT_COUNTRY=IR

# UI Theme: dark, light
THEME=dark

# Display Mode: web, cli, both
DISPLAY_MODE=web

# API Configuration
REQUEST_TIMEOUT=10
MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/weather_dashboard.log

# Features
ENABLE_FORECAST=true
ENABLE_ALERTS=true
ENABLE_HISTORY=true
ENABLE_CHARTS=true
